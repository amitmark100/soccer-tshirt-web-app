  "description": "Soccer Jersey Store REST API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc & node dist/index.js",
    "dev": "nodemon --exec ts-node --transpile-only src/index.ts",
    "dev:watch": "tsc --watch",
