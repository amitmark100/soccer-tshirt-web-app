    "mongoose": "^7.5.0",
    "multer": "^2.1.0",
    "openai": "^6.34.0",
    "pm2": "^6.0.14",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
